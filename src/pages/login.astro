---
import AuthLayout from '@/layouts/AuthLayout.astro';
import MainLayout from '@/layouts/MainLayout.astro';

if (Astro.locals.session) {
  return Astro.redirect('/protected');
}

const email = Astro.cookies.get('email')?.value ?? '';
const rememberme = !!email;
---

<MainLayout title="Auth - Login">
  <AuthLayout>
    <div class="p-12 bg-white mx-auto rounded-2xl w-100">
      <div class="mb-4">
        <h3 class="font-semibold text-2xl text-gray-800">Login</h3>
        <p class="text-gray-500">Por favor ingresa tus datos.</p>
      </div>
      <form id="login-form" class="space-y-5">
        <div id="error-message" class="hidden text-red-600 text-sm bg-red-50 border border-red-200 rounded-lg p-3">
        </div>
        <div class="space-y-2">
          <label class="text-sm font-medium text-gray-700 tracking-wide">Email</label>
          <input
            name="email"
            class="w-full text-base px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-400"
            type="email"
            value={email}
            placeholder="mail@gmail.com"
          />
        </div>
        <div class="space-y-2">
          <label class="mb-5 text-sm font-medium text-gray-700 tracking-wide"> Password </label>
          <input
            name="password"
            class="w-full content-center text-base px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-400"
            type="password"
            placeholder="Enter your password"
          />
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <input
              id="remember_me"
              name="remember_me"
              type="checkbox"
              checked={rememberme}
              class="h-4 w-4 bg-blue-500 focus:ring-blue-400 border-gray-300 rounded"
            />
            <label for="remember_me" class="ml-2 block text-sm text-gray-800"> Recuerda me </label>
          </div>
          <div class="text-sm">
            <a href="/registry" class="text-green-400 hover:text-green-500"> No tienes cuenta.? </a>
          </div>
        </div>
        <div>
          <button
            id="btn-submit"
            type="submit"
            class="disabled:bg-gray-300 w-full flex justify-center bg-green-400 hover:bg-green-500 text-gray-100 p-3 rounded-full tracking-wide font-semibold shadow-lg cursor-pointer transition ease-in duration-500"
          >
            Sign in
          </button>
        </div>
      </form>
      <div class="pt-5 text-center text-gray-400 text-xs">
        <span>
          Copyright © 2021- {new Date().getFullYear()}
          <a
            href="https://codepen.io/uidesignhub"
            rel=""
            target="_blank"
            title="Ajimon"
            class="text-green hover:text-green-500">AJI</a
          ></span
        >
      </div>
    </div>
  </AuthLayout>
</MainLayout>

<script>
  import { authClient } from '@/lib/auth-client';

  const form = document.querySelector('#login-form') as HTMLFormElement;
  const btnSubmit = document.querySelector('#btn-submit') as HTMLButtonElement;
  const errorMessage = document.querySelector('#error-message') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const originalText = btnSubmit.innerHTML;
    btnSubmit.innerHTML = 'Ingresando...';
    btnSubmit.setAttribute('disabled', 'disabled');
    errorMessage.classList.add('hidden');
    errorMessage.textContent = '';

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const rememberMe = formData.get('remember_me') === 'on';

    const { data, error } = await authClient.signIn.email({
      email,
      password,
      rememberMe,
    });

    if (error) {
      errorMessage.textContent = error.message || 'Error al iniciar sesión';
      errorMessage.classList.remove('hidden');
      btnSubmit.innerHTML = originalText;
      btnSubmit.removeAttribute('disabled');
    } else {
      // Set or clear the remember_me cookie
      if (rememberMe) {
        // 7 days in seconds
        document.cookie = `email=${encodeURIComponent(email)}; max-age=${7 * 24 * 60 * 60}; path=/; SameSite=Lax`;
      } else {
        // Remove the cookie
        document.cookie = 'email=; max-age=0; path=/; SameSite=Lax';
      }
      // Éxito: redirigir a la página protegida o al home
      window.location.href = '/protected';
    }
  });
</script>
