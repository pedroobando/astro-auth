---
import ContentLayout from '@/layaouts/ContentLayout.astro';
import MainLayout from '@/layaouts/MainLayout.astro';

const user = Astro.locals.user;
---

<MainLayout title="Área Protegida">
  <ContentLayout>
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold text-gray-800 mb-2">Área Protegida</h1>
        <p class="text-gray-500">Solo usuarios autenticados pueden ver esta página.</p>
      </div>

      <!-- Tarjeta de usuario -->
      <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">
        <!-- Banner superior con gradiente -->
        <div class="h-32 bg-gradient-to-r from-green-400 to-emerald-500"></div>

        <!-- Contenido de la tarjeta -->
        <div class="px-8 pb-8 -mt-16 relative">
          <!-- Avatar -->
          <div class="flex justify-center">
            <div class="w-32 h-32 rounded-full border-4 border-white bg-gray-200 flex items-center justify-center shadow-md overflow-hidden">
              {user?.image ? (
                <img src={user.image} alt={user.name} class="w-full h-full object-cover" />
              ) : (
                <span class="text-4xl font-bold text-gray-400">
                  {user?.name?.charAt(0)?.toUpperCase() ?? 'U'}
                </span>
              )}
            </div>
          </div>

          <!-- Info del usuario -->
          <div class="mt-6 text-center">
            <h2 class="text-2xl font-bold text-gray-800">{user?.name ?? 'Usuario'}</h2>
            <p class="text-gray-500 mt-1">{user?.email ?? 'email@example.com'}</p>

            <!-- Badge de estado -->
            <div class="mt-3 inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-700 text-sm font-medium">
              <span class="w-2 h-2 rounded-full bg-green-500 mr-2"></span>
              Sesión activa
            </div>
          </div>

          <!-- Detalles -->
          <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold">ID de Usuario</p>
              <p class="text-sm text-gray-700 mt-1 font-mono break-all">{user?.id ?? 'N/A'}</p>
            </div>
            <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Email Verificado</p>
              <p class="text-sm text-gray-700 mt-1">
                {user?.emailVerified ? (
                  <span class="text-green-600 font-medium">✓ Verificado</span>
                ) : (
                  <span class="text-amber-600 font-medium">⏳ Pendiente</span>
                )}
              </p>
            </div>
            <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Cuenta creada</p>
              <p class="text-sm text-gray-700 mt-1">
                {user?.createdAt ? new Date(user.createdAt).toLocaleDateString('es-ES', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                }) : 'N/A'}
              </p>
            </div>
            <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Última actualización</p>
              <p class="text-sm text-gray-700 mt-1">
                {user?.updatedAt ? new Date(user.updatedAt).toLocaleDateString('es-ES', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                }) : 'N/A'}
              </p>
            </div>
          </div>

          <!-- Botón de logout -->
          <div class="mt-8 flex justify-center">
            <button
              id="btn-logout"
              class="flex items-center gap-2 px-6 py-3 bg-red-500 hover:bg-red-600 text-white rounded-full font-medium shadow-lg shadow-red-200 transition-all duration-300 hover:shadow-xl hover:-translate-y-0.5 cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              Cerrar sesión
            </button>
          </div>
        </div>
      </div>

      <!-- Info adicional -->
      <div class="mt-8 bg-blue-50 rounded-2xl p-6 border border-blue-100">
        <h3 class="text-lg font-semibold text-blue-800 mb-2">¿Cómo funciona?</h3>
        <p class="text-blue-700 text-sm leading-relaxed">
          Esta página está protegida por el middleware de Astro. Si intentás acceder sin estar logueado,
          el middleware detecta que no hay sesión activa y te redirige automáticamente al login.
          Los datos del usuario se inyectan en <code class="bg-blue-100 px-1.5 py-0.5 rounded text-blue-800 font-mono text-xs">Astro.locals</code> desde el middleware.
        </p>
      </div>
    </div>
  </ContentLayout>
</MainLayout>

<script>
  import { authClient } from '@/lib/auth-client';

  const btnLogout = document.querySelector('#btn-logout') as HTMLButtonElement;

  btnLogout.addEventListener('click', async () => {
    btnLogout.setAttribute('disabled', 'disabled');
    btnLogout.textContent = 'Cerrando sesión...';

    try {
      await authClient.signOut();
      window.location.href = '/login';
    } catch (err) {
      console.error('Error al cerrar sesión:', err);
      btnLogout.removeAttribute('disabled');
      btnLogout.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Cerrar sesión
      `;
    }
  });
</script>
