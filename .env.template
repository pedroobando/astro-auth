# Variables de entorno para el proyecto astro-auth
# Copiá este archivo a `.env` y completá con tus valores reales.
# NO commitear el archivo `.env`.

# URL base del proyecto (desarrollo)
BETTER_AUTH_URL=http://localhost:4321

# Secreto para firmar sesiones de better-auth (generá uno seguro con: openssl rand -base64 32)
BETTER_AUTH_SECRET=tu-secreto-aqui

# URL de la base de datos Turso (libSQL)
TURSO_DATABASE_URL=libsql://tu-db.turso.io

# Token de autenticación de Turso (obtenelo desde el dashboard de Turso)
TURSO_AUTH_TOKEN=tu-token-aqui

# API Key de Resend para enviar emails (obtenelo desde https://resend.com/api-keys)
RESEND_APIKEY=re_tu-api-key-aqui
